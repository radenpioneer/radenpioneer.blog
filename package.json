{
  "name": "@example/minimal",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "astro": "astro",
    "prebuild": "pnpm dlx npm-run-all -p check:*",
    "build": "astro build",
    "check:lint": "astro check && tsc --noEmit",
    "check:style": "pnpm exec prettier --plugin-search-dir=. --check .",
    "dev": "astro dev",
    "format": "pnpm exec prettier --plugin-search-dir=. --write .",
    "preview": "astro preview",
    "start": "astro dev"
  },
  "dependencies": {
    "@picocss/pico": "^1.5.7",
    "astro": "^2.0.14"
  },
  "devDependencies": {
    "sass": "^1.57.1",
    "typescript": "^4.9.5"
  }
}
