---
import Layout, { type Props as LProps } from './layout.astro'
import Header from '~/components/common/header/header.astro'
import Gradient from '~/components/common/gradient/gradient.astro'

export interface Props extends LProps {}
const { ...props } = Astro.props
---

<Layout {...props}>
  <main
    class='prose lg:prose-lg prose-theme relative mx-auto max-w-screen-lg px-4 pt-8 pb-48 sm:px-8 xl:px-0'
  >
    {
      props.title && (
        <Header title={props.title} className='not-prose mb-6 xl:mb-8' />
      )
    }

    <slot />
    <Gradient class='fixed inset-x-0 bottom-0 h-48' />
  </main>
</Layout>
