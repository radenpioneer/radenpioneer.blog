---
import { getEntry } from 'astro:content'

export interface Props {
  title?: string | undefined
  description?: string | undefined
  hide?: boolean | undefined
}

const { title, description, hide } = Astro.props
const site = await getEntry('site', 'site')
---

{/* Essential Metadata */}
<title>
  {
    title
      ? `${title} \u2014 ${site?.data.title}`
      : `${site?.data.title} \u2014 ${site?.data.description}`
  }
</title>
<meta name='description' content={description || site?.data.description} />

{/* Icons */}
<link rel='icon' type='image/svg+xml' href='/favicon.svg' />

{/* Visibility Settings */}
{hide && <meta name='robots' content='noindex, nofollow' />}
