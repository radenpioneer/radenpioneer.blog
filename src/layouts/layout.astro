---
import BaseLayout, { type Props as BLProps } from './base.astro'
import Meta, { type Props as MetaProps } from './meta.astro'
import Menu from '~/components/common/menu/menu.astro'
import { ClientRouter } from 'astro:transitions'
import Scan from '~/components/dev/scan.astro'
import '@fontsource-variable/lexend'
import './globals.css'

export interface Props extends BLProps, MetaProps {}
const { title, description, hide, class: className, ...props } = Astro.props
---

<BaseLayout
  class:list={[
    'h-dvh overflow-hidden select-none',
    'text-theme-text from-primary-300 to-theme bg-radial-[at_95%_5%] to-50%',
    'dark:text-theme-text-dark dark:bg-theme-dark dark:bg-none',
    className
  ]}
  {...props}
>
  {/* <body/> */}
  <slot />
  <Menu />

  {/* <head/> */}
  <Fragment slot='head'>
    <Meta {...{ title, description, hide }} />
    <ClientRouter />
    <slot name='head' />
  </Fragment>

  {/* Devtools */}
  {
    import.meta.env.DEV && (
      <Fragment>
        <Scan />
      </Fragment>
    )
  }
</BaseLayout>
