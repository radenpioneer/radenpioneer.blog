---
import type { HomeFeaturedProps } from './featured'
import HomeFeatured from './featured'
import { getPicture } from '@astrojs/image'

const SCREENSHOT_BASE_URL = 'https://api.sngr.studio/generate'
const { title, subtitle, link, url } = Astro.props as HomeFeaturedProps

const renderedImageDesktop = await getPicture({
  src: `${SCREENSHOT_BASE_URL}?url=${link}&w=1280w&h=720h`,
  alt: title,
  widths: [1280],
  formats: ['avif', 'webp', 'jpeg'],
  aspectRatio: 1280 / 720,
})
const renderedImageMobile = await getPicture({
  src: `${SCREENSHOT_BASE_URL}?url=${link}&w=393w&h=851h`,
  alt: title,
  widths: [393],
  formats: ['avif', 'webp', 'jpeg'],
  aspectRatio: 393 / 851,
})
---

<HomeFeatured
  title={title}
  subtitle={subtitle || ''}
  link={link}
  url={url}
  renderedImages={{
    desktop: renderedImageDesktop,
    mobile: renderedImageMobile,
  }}
/>
